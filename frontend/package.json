{
  "name": "fortnite-pronos-app-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration development --hmr --live-reload --poll=1000",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest",
    "test:vitest:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:audit013": "ng test --watch=false --browsers=ChromeHeadless --include src/app/features/game/services/game-data.service.spec.ts --include src/app/features/game/join-game/join-game.component.spec.ts --include src/app/shared/components/main-layout/main-layout.component.spec.ts",
    "audit:i18n": "node scripts/i18n-audit.js",
    "serve:ssr:frontend": "node dist/frontend/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.17",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.17",
    "@angular/compiler": "^20.3.17",
    "@angular/core": "^20.3.17",
    "@angular/forms": "^20.3.17",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.17",
    "@angular/platform-server": "^20.3.17",
    "@angular/router": "^20.3.17",
    "@angular/ssr": "^20.3.18",
    "@stomp/stompjs": "^7.3.0",
    "chart.js": "^4.5.1",
    "express": "^5.2.1",
    "ng2-charts": "^8.0.0",
    "rxjs": "~7.8.0",
    "sockjs-client": "^1.6.1",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^1.17.1",
    "@angular/build": "^20.3.18",
    "@angular/cli": "^20.3.18",
    "@angular/compiler-cli": "^20.3.17",
    "@playwright/test": "^1.58.2",
    "@types/express": "^5.0.1",
    "@types/jasmine": "^5.1.15",
    "@types/node": "^20.19.35",
    "@types/sockjs-client": "^1.5.4",
    "@vitest/coverage-v8": "^3.2.4",
    "jasmine-core": "~5.7.0",
    "jsdom": "^28.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.8.2",
    "vitest": "^3.2.4"
  }
}
