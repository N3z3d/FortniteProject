# Supabase (required for ingestion script)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SCHEMA=public
SUPABASE_SEED_GAME_ID=

# Scraping providers (at least one required)
SCRAPFLY_KEYS=your-scrapfly-key-1,your-scrapfly-key-2
SCRAPERAPI_KEYS=your-scraperapi-key-1,your-scraperapi-key-2
SCRAPEDO_TOKEN=your-scrapedo-token
SCRAPEDO_TOKENS=
SCRAPERAPI_RENDER=false

# Scrape settings
SCRAPE_PLATFORM=pc
SCRAPE_TIMEFRAME=year
SCRAPE_PAGE_SIZE=100
SCRAPE_GLOBAL_PAGES=21
SCRAPE_REGION_PAGES=3
SCRAPE_INCLUDE_GLOBAL=false
SCRAPE_CHUNK_SIZE=40
SCRAPE_MAX_ATTEMPTS=8
SCRAPE_TIMEOUT_MS=20000
SCRAPFLY_WEIGHT=1
SCRAPERAPI_WEIGHT=1
SCRAPEDO_WEIGHT=1
SCRAPEDO_BASE_URL=http://api.scrape.do/
SCRAPE_DEBUG=false

# Fortnite API (fortnite-api.com — gratuit, inscription via https://dash.fortnite-api.com)
FORTNITE_API_KEY=your-fortnite-api-key-here
FORTNITE_API_URL=https://fortnite-api.com/v2/stats/br/v2

# Production infrastructure secrets
REDIS_PASSWORD=your-strong-redis-password-here
GRAFANA_PASSWORD=your-strong-grafana-password-here

# NVD API Key (OWASP dependency-check — gratuit, inscription via https://nvd.nist.gov/developers/request-an-api-key)
# Sans cette clé, mvn dependency-check:check retourne 403 et échoue
NVD_API_KEY=your-nvd-api-key-here

# E2E Test variables (Playwright)
# Ces comptes sont seedés automatiquement sur le profil dev (db/seed/V1001__...)
# Le login principal E2E passe actuellement par les boutons de profil.
# E2E_USER / E2E_PASS servent au fallback par identifiant ou aux usages API ciblés.
# Mot de passe commun des comptes seedés : Admin1234
E2E_USER=thibaut@fortnite-pronos.com
E2E_PASS=Admin1234
E2E_USER2=marcel@fortnite-pronos.com
E2E_PASS2=Admin1234
BASE_URL=http://localhost:8080
BACKEND_URL=http://localhost:8080

# Ingestion settings
INGESTION_SOURCE=FORTNITE_TRACKER
INGESTION_SEASON=2025
INGESTION_BATCH_SIZE=500
INGESTION_WRITE_SCORES=true
SCORE_STRATEGY=MAX
INGESTION_LOOKUP_BATCH_SIZE=50
SNAPSHOT_DATE=
